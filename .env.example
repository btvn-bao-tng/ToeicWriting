# AI provider (OpenAI-compatible chat completions endpoint)
AI_BASE_URL=http://localhost:20128/v1
AI_MODEL=cx/gpt-5.4
AI_API_KEY=

# Database
# Defaults to sqlite:///data/database.db when unset.
# Use postgresql+psycopg://... or postgres://... for Postgres.
# DATABASE_URL=sqlite:///data/database.db
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
# DB_POOL_SIZE=2
# DB_MAX_OVERFLOW=0
# DB_POOL_RECYCLE_SECONDS=1800
# DB_POOL_PRE_PING=false

# Limits
# MAX_IMAGE_ATTACHMENTS=3
# MAX_IMAGE_BYTES=8388608

# Multiuser / sessions
# SECRET_KEY: required for stable signed session cookies. If unset, a random
# ephemeral key is generated on each startup (sessions will not survive restart).
SECRET_KEY=
# ALLOW_SIGNUP: set to "false" to disable public self-registration.
# ALLOW_SIGNUP=true
# SESSION_COOKIE_NAME: override the default cookie name (tw_session).
# SESSION_COOKIE_NAME=tw_session

# Google OAuth (Gmail sign-in)
# Create credentials at https://console.cloud.google.com/apis/credentials
# (OAuth client type "Web application"). Add the callback URL below to the
# "Authorized redirect URIs" list:
#   http://localhost:8000/api/auth/google/callback
# When GOOGLE_REDIRECT_URI is empty, the server derives it from the request,
# which works for local development. Behind a proxy, set it explicitly to the
# public callback URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
